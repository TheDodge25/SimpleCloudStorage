# MinIO
# ⚠️  CHANGE THESE before any internet-facing deployment.
# Default credentials are public knowledge and will be exploited.
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_BUCKET_NAME=drive-files
MINIO_ENDPOINT=minio:9000

# MongoDB
MONGO_URL=mongodb://mongo:27017
MONGO_DB_NAME=drivedb

# Backend (internal Docker URL used by SvelteKit server-side load functions)
BACKEND_URL=http://backend:8000

# CORS — allow nginx origin in Docker; allow localhost for local dev
BACKEND_CORS_ORIGINS=["http://localhost","http://localhost:3000"]

# ── Auth ─────────────────────────────────────────────────────────────────────
# ⚠️  Generate a strong random secret before deploying:
#   python -c "import secrets; print(secrets.token_hex(64))"
# NEVER commit the real value of this variable.
JWT_SECRET=change-me-to-a-long-random-string

JWT_ALGORITHM=HS256

# How long an access token is valid (minutes). Default: 15
ACCESS_TOKEN_EXPIRE_MINUTES=15

# How long a refresh token is valid (days). Default: 30
REFRESH_TOKEN_EXPIRE_DAYS=30

# ── Storage quotas ────────────────────────────────────────────────────────────
# Per-user storage quota in bytes. Default: 10 GB
DEFAULT_QUOTA_BYTES=10737418240
