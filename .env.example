# MinIO
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_BUCKET_NAME=drive-files
MINIO_ENDPOINT=minio:9000

# MongoDB
MONGO_URL=mongodb://mongo:27017
MONGO_DB_NAME=drivedb

# Backend (internal Docker URL used by SvelteKit server-side load functions)
BACKEND_URL=http://backend:8000

# CORS — allow nginx origin in Docker; allow localhost for local dev
BACKEND_CORS_ORIGINS=http://localhost,http://localhost:3000
